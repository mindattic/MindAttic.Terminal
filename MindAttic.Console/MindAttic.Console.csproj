<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>MindAttic.Console</RootNamespace>
    <AssemblyName>MindAttic.Console</AssemblyName>
    <Version>0.1.0</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationIcon>M.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="M.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MindAttic.Vault" Version="0.2.0" />
    <PackageReference Include="Spectre.Console" Version="0.49.1" />
    <PackageReference Include="Spectre.Console.Cli" Version="0.49.1" />
  </ItemGroup>

</Project>
